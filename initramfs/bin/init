#!/bin/sh

# Mount essential filesystems
echo "[*] Mounting essential filesystems"
mkdir -p /proc
mkdir -p /run
mount -t proc none /proc
mkdir -p /sys
mount -t sysfs none /sys
mount -t devtmpfs none /dev

# Set up PATH
echo "[*] Setting up PATH"
export PATH=/bin

# Launch installer
/bin/install
exec /bin/sh
