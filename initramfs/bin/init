#!/bin/sh

# Mount essential filesystems
echo "\033[96m*\033[0m Mounting essential filesystems"
mkdir -p /proc
mkdir -p /run
mount -t proc none /proc
mkdir -p /sys
mount -t sysfs none /sys
mount -t devtmpfs none /dev

# Set up PATH
echo "\033[96m*\033[0m Setting up PATH"
export PATH=/bin

mdev -s

# Launch installer
exec /bin/install
