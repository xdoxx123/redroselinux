# use this file to change your session, for example a shell. by default, this file will start getty.
TTY_LIST="tty1 tty2 tty3 tty4 tty5 tty6"
for TTY in $TTY_LIST
do
(
    while true
    do
        busybox clear
        busybox getty -L "$TTY" 115200 vt100 \
            -l /bin/login \
            -I "\e[31mRedrose Linux\e[0m\nMost of Redrose Linux is licensed under GPLv3 and comes with NO WARRANTY.\nThird-party software in Redrose Linux retains its own license terms.\n"
    done
) &
done
wait
